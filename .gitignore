# ── Python ──────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Environment variables (NEVER commit) ────────────
.env
.env.local
.env.production
.env*.local

# ── Next.js frontend ─────────────────────────────────
frontend/.next/
frontend/node_modules/
frontend/out/
frontend/.vercel/

# ── If your frontend folder has a different name ─────
# change "frontend" to match your actual folder name
# e.g. if it's called "laborlens-frontend" update above

# ── Documents (PDFs can be large) ────────────────────
documents/

# ── OS files ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code ──────────────────────────────────────────
.vscode/

# ── Logs ─────────────────────────────────────────────
*.log
logs/
